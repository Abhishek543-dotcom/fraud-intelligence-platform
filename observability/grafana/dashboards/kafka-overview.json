{
  "uid": "kafka-overview",
  "title": "Kafka Overview",
  "tags": ["kafka", "streaming"],
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Consumer Lag (Total)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(kafka_consumergroup_lag_sum)", "legendFormat": "Total Lag", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] } } }
    },
    {
      "id": 2, "type": "stat", "title": "Messages In/sec",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(rate(kafka_server_brokertopicmetrics_messagesin_total[1m]))", "legendFormat": "msg/s", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 3, "type": "stat", "title": "Bytes In/sec",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(rate(kafka_server_brokertopicmetrics_bytesin_total[1m]))", "legendFormat": "bytes/s", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 4, "type": "stat", "title": "Active Partitions",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "kafka_server_replicamanager_partitioncount", "legendFormat": "Partitions", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Consumer Lag by Topic",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "sum(kafka_consumergroup_lag_sum) by (topic)", "legendFormat": "{{ topic }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Bytes In/Out by Topic",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "sum(rate(kafka_server_brokertopicmetrics_bytesin_total[1m])) by (topic)", "legendFormat": "in: {{ topic }}", "refId": "A" },
        { "expr": "sum(rate(kafka_server_brokertopicmetrics_bytesout_total[1m])) by (topic)", "legendFormat": "out: {{ topic }}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ],
  "schemaVersion": 39
}
