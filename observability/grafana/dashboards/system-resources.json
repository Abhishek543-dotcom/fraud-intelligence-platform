{
  "uid": "system-resources",
  "title": "System Resources",
  "tags": ["infrastructure", "resources"],
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "CPU Usage by Container",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(process_cpu_seconds_total[1m])", "legendFormat": "{{ job }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 2, "type": "timeseries", "title": "Memory Usage by Container",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "process_resident_memory_bytes", "legendFormat": "{{ job }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 30, "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 3, "type": "timeseries", "title": "Disk I/O",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[1m])", "legendFormat": "read {{ device }}", "refId": "A" },
        { "expr": "rate(node_disk_written_bytes_total[1m])", "legendFormat": "write {{ device }}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 4, "type": "timeseries", "title": "Network I/O",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total[1m])", "legendFormat": "rx {{ device }}", "refId": "A" },
        { "expr": "rate(node_network_transmit_bytes_total[1m])", "legendFormat": "tx {{ device }}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    }
  ],
  "schemaVersion": 39
}
