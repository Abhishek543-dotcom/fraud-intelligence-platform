{
  "uid": "spark-streaming",
  "title": "Spark Streaming",
  "tags": ["spark", "streaming"],
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Records Processed/sec",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(spark_streaming_totalProcessedRecords[1m])", "legendFormat": "rec/s", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 2, "type": "stat", "title": "Batch Duration (last)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "spark_streaming_lastCompletedBatch_processingTime_seconds", "legendFormat": "duration", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 60 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Scheduling Delay",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "spark_streaming_lastCompletedBatch_schedulingDelay_seconds", "legendFormat": "delay", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4, "type": "stat", "title": "Active Queries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "spark_streaming_activeQueries", "legendFormat": "queries", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Processing Time Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "spark_streaming_lastCompletedBatch_processingTime_seconds", "legendFormat": "Processing Time", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 20 } } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Records Per Batch",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [{ "expr": "spark_streaming_lastCompletedBatch_numInputRows", "legendFormat": "Records", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } } }
    }
  ],
  "schemaVersion": 39
}
