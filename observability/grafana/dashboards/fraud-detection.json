{
  "uid": "fraud-detection",
  "title": "Fraud Detection",
  "tags": ["fraud", "ml", "detection"],
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Fraud Alerts/min",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "rate(fraud_alerts_total[5m]) * 60", "legendFormat": "alerts/min", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 50 }] } } }
    },
    {
      "id": 2, "type": "stat", "title": "Fraud Rate",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "rate(fraud_alerts_total[5m]) / (rate(fraud_transactions_total[5m]) + 0.001)", "legendFormat": "rate", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.03 }, { "color": "red", "value": 0.1 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Model Latency (P95)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(fraud_model_inference_duration_seconds_bucket[5m]))", "legendFormat": "p95", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4, "type": "stat", "title": "Model Accuracy",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "fraud_model_accuracy", "legendFormat": "accuracy", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Fraud Score Distribution Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(fraud_score_distribution_bucket[5m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.90, rate(fraud_score_distribution_bucket[5m]))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(fraud_score_distribution_bucket[5m]))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 6, "type": "piechart", "title": "Top Fraud Types",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [{ "expr": "sum(fraud_alerts_total) by (fraud_type)", "legendFormat": "{{ fraud_type }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ],
  "schemaVersion": 39
}
