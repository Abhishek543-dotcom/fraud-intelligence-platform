{
  "uid": "api-latency",
  "title": "API Latency",
  "tags": ["api", "backend", "latency"],
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Request Rate",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"backend\"}[1m]))", "legendFormat": "req/s", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2, "type": "stat", "title": "Error Rate (5xx)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"backend\", status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"backend\"}[5m]))", "legendFormat": "error %", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "P50 Latency",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.5, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))", "legendFormat": "p50", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4, "type": "stat", "title": "P95 Latency",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))", "legendFormat": "p95", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5, "type": "stat", "title": "P99 Latency",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))", "legendFormat": "p99", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "red", "value": 0.5 }] } } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Latency Percentiles Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"backend\"}[5m]))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Request Rate by Endpoint",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"backend\"}[1m])) by (handler)", "legendFormat": "{{ handler }}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ],
  "schemaVersion": 39
}
