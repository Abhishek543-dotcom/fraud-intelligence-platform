# =============================================================================
# Fraud Intelligence Platform - .gitignore
# =============================================================================

# Environment
.env
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Docker volumes (local data)
volumes/
data/

# Spark
spark-warehouse/
metastore_db/
derby.log

# Airflow
airflow/logs/
airflow/plugins/__pycache__/

# ML Models (large files)
models/*.pkl
models/*.joblib
models/*.pt
models/*.onnx

# Logs
*.log
logs/

# Coverage
htmlcov/
.coverage
coverage.xml

# Jupyter
.ipynb_checkpoints/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfvars

# Secrets
*.pem
*.key
*.crt
credentials/
