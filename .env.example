# =============================================================================
# Fraud Intelligence Platform - Environment Configuration Template
# Copy to .env and fill in values
# =============================================================================

# --- Kafka ---
KAFKA_BROKER=kafka:9092
KAFKA_EXTERNAL_BROKER=localhost:9094
KAFKA_KRAFT_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# --- MinIO (S3-compatible object store) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_IN_PRODUCTION
MINIO_CONSOLE_PORT=9001

# --- PostgreSQL ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=airflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Nessie (Iceberg catalog) ---
NESSIE_URI=http://nessie:19120/api/v1
NESSIE_EXTERNAL_URI=http://localhost:19120/api/v1
ICEBERG_WAREHOUSE=s3://lakehouse/warehouse

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:CHANGE_ME@postgres:5432/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=CHANGE_ME_IN_PRODUCTION
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false

# --- Spark ---
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_WEBUI_PORT=8081
SPARK_WORKER_MEMORY=896m
SPARK_WORKER_CORES=2

# --- Ollama (LLM) ---
OLLAMA_HOST=http://ollama:11434
OLLAMA_EXTERNAL_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# --- ChromaDB (Vector store) ---
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# --- Redis ---
REDIS_URL=redis://redis:6379/0
REDIS_EXTERNAL_URL=redis://localhost:6379/0

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8888
BACKEND_WORKERS=2

# --- Frontend ---
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8888

# --- Platform ---
ENVIRONMENT=development
LOG_LEVEL=INFO
